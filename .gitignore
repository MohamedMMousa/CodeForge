## Ignore Visual Studio temporary files, build results, and
## files generated by popular IDEs.
## Source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/ActiveWriter)
*.userprefs

# Mono auto generated files
*.pidb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bin]/
[Obj]/
[Log]/
[Logs]/

# Visual Studio 2015/2017 cache directory
.vs/
# Generated files
# (keep these comments so they are preserved)

# MSTest test Results
[T]est[R]esult*/
[B]uild[L]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent-conhost.exe.config

# Build Office Add-ins
~*

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Re]Sharper
*.DotSettings.user

# JustCode printer files
.JustCode

# TeamCity is a build chain tool
_TeamCity*

# DotCover is a Code Coverage Tool
*.dotCover

# AxoCover is a Code Coverage Tool
.axoCover/*
!.axoCover/settings.json

# Coverlet is a free, cross-platform Code Coverage Tool
ipr/

# Visual Studio cache files
# Do not press git tracking
*.dbmdl
*.playground

# Files built by Visual Studio
*.pdb
*.aps
*.pch
*.vspscc
*.vsscc
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vspscc
*.vsscc
*.webinfo
*.csproj.user
*.publishproj
*.dbmdl

# MSBuild Code Analysis output
*.CodeAnalysisLog.xml
*.lastcodeanalysissucceeded

# Tooling
_Chutzpah*
ipch/
*.ap結
*.ncb
*.sdf
*.suo
*.tlb
*.tlh
*.opensdf
*.db
*.db-shm
*.db-wal

# Output folders
bin/
obj/

# OS metadata
.DS_Store
Thumbs.db

# VS Code directories
.vscode/

# Rider directories
.idea/
