@using Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CodeForge Academy — ابنِ المستقبل بالتكنولوجيا</title>
    <meta name="description" content="أكاديمية مصرية متخصصة في تعليم البرمجة والذكاء الاصطناعي للمراهقين من ١٥ إلى ١٨ سنة. حصص مباشرة، مشاريع حقيقية، ومدربين محترفين." />
    <meta name="keywords" content="CodeForge Academy, programming, AI, teenagers, Egypt, coding, أكاديمية, برمجة, ذكاء اصطناعي, مراهقين" />
    <meta property="og:title" content="CodeForge Academy — ابنِ المستقبل بالتكنولوجيا" />
    <meta property="og:description" content="أكاديمية مصرية متخصصة في تعليم البرمجة والذكاء الاصطناعي للمراهقين." />
    <meta property="og:type" content="website" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Styles -->
    <link rel="stylesheet" href="~/css/variables.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/sections.css" />
    <link rel="stylesheet" href="~/css/animations.css" />
</head>
<body>
    @RenderBody()

    <!-- Scripts -->
    <script src="~/js/language.js"></script>
    <script src="~/js/navigation.js"></script>
    <script src="~/js/animations.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
