@page
@model IndexModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment
@{
    ViewData["Title"] = "CodeForge Academy";

    // Auto-detect logo files in wwwroot/images/
    string? resolvedLogoUrl = null;
    var extensions = new[] { "svg", "png", "jpg", "jpeg", "webp" };
    foreach (var ext in extensions)
    {
        var relativePath = $"images/logo.{ext}";
        var absolutePath = System.IO.Path.Combine(WebHostEnvironment.WebRootPath ?? "", relativePath);
        if (System.IO.File.Exists(absolutePath))
        {
            resolvedLogoUrl = relativePath;
            break;
        }
    }
}

