    <div class="container navbar-inner">
        <a href="#" class="navbar-logo">
            @if (resolvedLogoUrl != null)
            {
                <img src="~/@resolvedLogoUrl" alt="CodeForge Logo" style="height: 60px; width: auto; margin-rights: var(--space-3);" />
            }
           
            <span class="navbar-logo-text">CodeForge</span>
        </a>

        <div class="navbar-links">
            <a href="#features" class="navbar-link" data-i18n="navFeatures">What We Teach</a>
            <a href="#courses" class="navbar-link" data-i18n="navCourses">Programs</a>
            <a href="#how-it-works" class="navbar-link" data-i18n="navHowItWorks">How It Works</a>
            <a href="#results" class="navbar-link" data-i18n="navResults">Results</a>
            <a href="#about" class="navbar-link" data-i18n="navAbout">About Us</a>
        </div>

        <div class="navbar-actions">
            <div class="lang-toggle">
