<!-- ── HERO SECTION ── -->
<header class="hero">
    <div class="hero-glow-1"></div>
    <div class="hero-glow-2"></div>
    <div class="hero-grid"></div>
    <div class="container hero-content">
        <div class="hero-text reveal">
            <div class="hero-eyebrow" data-i18n="heroEyebrow">🚀 Registration is now open</div>
            <h1 class="hero-title">
                <span data-i18n="heroTitle1">Don't just learn technology.</span><br/>
                <span class="highlight" data-i18n="heroTitle2">Build it.</span>
            </h1>
            <p class="hero-subtitle" data-i18n="heroSubtitle">A specialized academy teaching Programming & AI to teenagers aged 15–18 through real projects and live classes.</p>
            <div class="hero-buttons">
                <a href="#" class="btn btn-primary btn-lg" data-whatsapp data-i18n="heroCta1">Register Now</a>
                <a href="#features" class="btn btn-secondary btn-lg" data-i18n="heroCta2">Learn More</a>
            </div>
        </div>

        <div class="hero-visual reveal" style="transition-delay: 200ms;">
            <div class="code-window">
                <div class="code-window-header">
                    <span class="code-window-dot red"></span>
                    <span class="code-window-dot yellow"></span>
                    <span class="code-window-dot green"></span>
                    <span class="code-window-title">codeforge_academy.py</span>
                </div>
                <div class="code-window-body">
                    <span class="code-line"><span class="code-keyword">import</span> academy, artificial_intelligence</span>
                    <span class="code-line"><span class="code-keyword">class</span> <span class="code-function">TeenStudent</span><span class="code-bracket">(</span>academy.Student<span class="code-bracket">)</span>:</span>
                    <span class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;<span class="code-keyword">def</span> <span class="code-function">learn_to_code</span><span class="code-bracket">(</span>self<span class="code-bracket">)</span>:</span>
                    <span class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;self.build_projects<span class="code-bracket">(</span><span class="code-string">"AI Chatbot"</span><span class="code-bracket">)</span></span>
                    <span class="code-line">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;self.create_future<span class="code-bracket">(</span><span class="code-bracket">)</span></span>
                    <span class="code-line"><span class="code-comment"># CodeForge Academy - 15 to 18 Years Old</span></span>
                    <span class="code-line">student = TeenStudent<span class="code-bracket">(</span>age=16<span class="code-bracket">)</span></span>
                    <span class="code-line">student.learn_to_code<span class="code-bracket">(</span><span class="code-bracket">)</span></span>
                    <span class="code-line"><span class="code-keyword">print</span><span class="code-bracket">(</span><span class="code-string">"Ready to build real technology!"</span><span class="code-bracket">)</span></span>
                </div>
            </div>
            <!-- Floating Badges -->
            <div class="floating-badge floating-badge-1">
                <span class="code-orange">&lt;/&gt;</span> Python
            </div>
            <div class="floating-badge floating-badge-2">
                <span class="code-orange">🧠</span> AI & ML
            </div>
            <div class="floating-badge floating-badge-3">
                <span class="code-orange">🌐</span> Web Dev
            </div>
        </div>
    </div>
</header>

